OPENAI_API_KEY=sk-your-openai-api-key-here
# REQUIRED in production. Generate one with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
# The app refuses to start with the built-in default when ENVIRONMENT != development.
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# Tier limits (optional overrides)
FREE_MAX_FILE_SIZE_MB=5
FREE_MAX_FILES=1
PRO_MAX_FILE_SIZE_MB=8
PRO_MAX_FILES=5

# Database (optional). Defaults to local SQLite. For Supabase Postgres:
#   DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_URL=sqlite:///./talktofile.db

# Supabase Auth (optional). When SUPABASE_JWT_SECRET is set, the backend verifies
# Supabase-issued JWTs instead of its own. Find these in the Supabase dashboard:
#   Project Settings → API → JWT Settings → "JWT Secret"
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Comma-separated emails granted the Pro plan automatically (test accounts /
# early users) until real billing exists. Applied on login.
# PRO_EMAILS=you@example.com,tester@example.com

# Password-reset emails (legacy custom auth). Uses Resend (https://resend.com).
# Leave RESEND_API_KEY blank in dev — reset links are then printed to the backend
# console instead of being emailed, so the flow is still fully testable.
#   EMAIL_FROM must be a verified sender/domain in your Resend account.
#   FRONTEND_URL is the base URL used to build reset links (defaults to the first
#   ALLOWED_ORIGINS entry). Set it to your public site URL in production.
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=TalkToFile <noreply@yourdomain.com>
# FRONTEND_URL=http://localhost:5173
# RESET_TOKEN_TTL_MINUTES=30
