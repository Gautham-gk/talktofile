# Supabase Auth (optional). When set, the frontend uses Supabase Auth instead of
# the legacy custom auth. Find these in the Supabase dashboard:
#   Project Settings → API → "Project URL" and "anon public" key
# VITE_SUPABASE_URL=https://<ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

# PostHog analytics (optional). Project token is public/safe in the frontend.
# Host: https://eu.i.posthog.com (EU) or https://us.i.posthog.com (US).
# VITE_POSTHOG_KEY=phc_xxx
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
