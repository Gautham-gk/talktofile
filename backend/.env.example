OPENAI_API_KEY=sk-your-openai-api-key-here
# REQUIRED in production. Generate one with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
# The app refuses to start with the built-in default when ENVIRONMENT != development.
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development

# Tier limits (optional overrides)
FREE_MAX_FILE_SIZE_MB=5
FREE_MAX_FILES=1
PRO_MAX_FILE_SIZE_MB=8
PRO_MAX_FILES=5

# Database (optional). Defaults to local SQLite. For Supabase Postgres:
#   DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# DATABASE_URL=sqlite:///./talktofile.db

# Supabase Auth (optional). When SUPABASE_JWT_SECRET is set, the backend verifies
# Supabase-issued JWTs instead of its own. Find these in the Supabase dashboard:
#   Project Settings → API → JWT Settings → "JWT Secret"
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_JWT_SECRET=your-supabase-jwt-secret
