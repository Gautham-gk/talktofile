# Compose-level env (docker compose reads this file automatically).
# NOTE: backend secrets live separately in backend/.env (OPENAI_API_KEY, SECRET_KEY,
# DATABASE_URL, SUPABASE_URL, SUPABASE_JWT_SECRET, ALLOWED_ORIGINS, ENVIRONMENT).

# Your public domain — drives Caddy's automatic HTTPS. Use "localhost" to test locally.
DOMAIN=talktofile.example.com

# Supabase (baked into the frontend at build time). Leave blank to use legacy auth.
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
